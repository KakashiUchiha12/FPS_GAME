[gd_scene load_steps=2 format=3]

[sub_resource type="GDScript" id="1"]
script/source = "extends Label3D

func _ready() -> void:
	billboard = 1 # BillboardMode.BILLBOARD_ENABLED
	double_sided = false
	no_depth_test = true
	
	# Random horizontal nudge
	position += Vector3(randf_range(-0.4, 0.4), randf_range(0.1, 0.4), randf_range(-0.4, 0.4))

	var tween := create_tween()
	tween.set_parallel(true)
	tween.tween_property(self, \"position:y\", position.y + 1.1, 0.7).set_ease(Tween.EASE_OUT)
	tween.tween_property(self, \"modulate:a\", 0.0, 0.7).set_ease(Tween.EASE_IN)
	tween.chain().tween_callback(queue_free)
"

[node name="FloatingNumber" type="Label3D"]
pixel_size = 0.0075
billboard = 1
double_sided = false
no_depth_test = true
text = "25"
font_size = 44
outline_size = 12
outline_color = Color(0, 0, 0, 1)
modulate = Color(1, 0.9, 0.2, 1)
script = SubResource("1")
